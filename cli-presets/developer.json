      {
        "icon": "⚡",
        "iconColor": "#22c55e",
        "name": "Node.js",
        "desc": "JavaScript 运行时",
        "methods": [
          {
            "label": "下载",
            "code": "https://nodejs.org"
          },
          {
            "label": "Windows",
            "code": "winget install OpenJS.NodeJS"
          }
        ]
      },
      {
        "icon": "🐍",
        "iconColor": "#f59e0b",
        "name": "Python",
        "desc": "通用编程语言",
        "methods": [
          {
            "label": "下载",
            "code": "https://python.org"
          },
          {
            "label": "Windows",
            "code": "winget install Python.Python.3.12"
          }
        ]
      },
      {
        "icon": "🦀",
        "iconColor": "#ef4444",
        "name": "Rust",
        "desc": "系统编程语言",
        "methods": [
          {
            "label": "安装",
            "code": "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh"
          }
        ]
      },
      {
        "icon": "🐙",
        "iconColor": "#6366f1",
        "name": "Git",
        "desc": "版本控制",
        "methods": [
          {
            "label": "Windows",
            "code": "winget install Git.Git"
          },
          {
            "label": "macOS",
            "code": "brew install git"
          }
        ]
      }
    ]
