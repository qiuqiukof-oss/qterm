  "welcome": {
    "quickStart": [
      {
        "icon": "1",
        "title": {
          "zh": "分析媒体",
          "en": "Analyze media"
        },
        "desc": {
          "zh": "用 ffprobe 检查音视频文件的编码、格式、元数据",
          "en": "Inspect audio/video encoding, format, metadata with ffprobe"
        }
      },
      {
        "icon": "2",
        "title": {
          "zh": "转码压缩",
          "en": "Transcode & compress"
        },
        "desc": {
          "zh": "用 ffmpeg 转换格式、压缩视频、提取音频",
          "en": "Convert formats, compress video, extract audio with ffmpeg"
        }
      },
      {
        "icon": "3",
        "title": {
          "zh": "生成字幕",
          "en": "Generate subtitles"
        },
        "desc": {
          "zh": "用 whisper 自动识别语音生成字幕文件",
          "en": "Auto-transcribe speech to subtitle files with whisper"
        }
      }
    ],
    "features": [
      {
        "icon": "🎬",
        "iconColor": "#ef4444",
        "title": {
          "zh": "视频转码",
          "en": "Video transcoding"
        },
        "desc": {
          "zh": "ffmpeg 全格式支持：H.264/H.265/VP9/AV1 编码",
          "en": "ffmpeg full-format: H.264/H.265/VP9/AV1 encoding"
        }
      },
      {
        "icon": "📝",
        "iconColor": "#6366f1",
        "title": {
          "zh": "字幕生成",
          "en": "Subtitle generation"
        },
        "desc": {
          "zh": "Whisper AI 语音识别，支持多语言自动转录",
          "en": "Whisper AI speech recognition, multilingual auto-transcription"
        }
      },
      {
        "icon": "🖼️",
        "iconColor": "#22c55e",
        "title": {
          "zh": "批量缩略图",
          "en": "Batch thumbnails"
        },
        "desc": {
          "zh": "ffmpeg + ImageMagick 自动提取帧创建蒙太奇",
          "en": "ffmpeg + ImageMagick auto frame-extraction montage"
        }
      },
      {
        "icon": "🔍",
        "iconColor": "#f59e0b",
        "title": {
          "zh": "媒体分析",
          "en": "Media analysis"
        },
        "desc": {
          "zh": "ffprobe/mediainfo/exiftool 深度媒体元数据",
          "en": "ffprobe/mediainfo/exiftool deep media metadata"
        }
      }
    ],
    "tips": [
      {
        "zh": "使用 <strong>ffprobe -v quiet -print_format json -show_format -show_streams input.mp4</strong> 获取完整媒体信息",
        "en": "Use <strong>ffprobe -v quiet -print_format json -show_format -show_streams input.mp4</strong> for full media info"
      },
      {
        "zh": "<strong>ffmpeg -i input.mp4 -c:v libx265 -crf 28 output.mp4</strong> H.265 压缩，体积减少 50%+",
        "en": "<strong>ffmpeg -i input.mp4 -c:v libx265 -crf 28 output.mp4</strong> H.265 compression, 50%+ smaller"
      },
      {
        "zh": "用 <strong>whisper audio.mp3 --model medium --language zh</strong> 生成中文字幕",
        "en": "Use <strong>whisper audio.mp3 --model medium --language zh</strong> to make Chinese subtitles"
      },
      {
        "zh": "按 <kbd>Ctrl+Shift+F</kbd> 在终端输出中搜索关键词",
        "en": "Press <kbd>Ctrl+Shift+F</kbd> to search terminal output"
      }
    ],
    "shortcuts": [
      {
        "key": "Ctrl+Shift+R",
        "desc": {
          "zh": "重新连接",
          "en": "Reconnect"
        }
      },
      {
