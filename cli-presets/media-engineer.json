      {
        "icon": "🎬",
        "iconColor": "#ef4444",
        "name": "FFmpeg",
        "desc": "音视频处理瑞士军刀",
        "methods": [
          {
            "label": "Windows",
            "code": "winget install FFmpeg"
          },
          {
            "label": "macOS",
            "code": "brew install ffmpeg"
          }
        ]
      },
      {
        "icon": "📝",
        "iconColor": "#6366f1",
        "name": "Whisper",
        "desc": "OpenAI 语音识别",
        "methods": [
          {
            "label": "pip",
            "code": "pip install openai-whisper"
          },
          {
            "label": "本地",
            "code": "pip install whisper-cpp"
          }
        ]
      },
      {
        "icon": "🖼️",
        "iconColor": "#22c55e",
        "name": "ImageMagick",
        "desc": "图片处理工具集",
        "methods": [
