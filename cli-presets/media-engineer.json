            "label": "Windows",
            "code": "winget install ImageMagick.ImageMagick"
          },
          {
            "label": "macOS",
            "code": "brew install imagemagick"
          }
        ]
      },
      {
        "icon": "🎵",
        "iconColor": "#f59e0b",
        "name": "yt-dlp",
        "desc": "视频下载工具",
