{
  "mcpServers": {
    "mastergo": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@mastergo/vibe-mcp",
        "--url=http://localhost:50678"
      ],
      "env": {
        "NO_PROXY": "localhost,127.0.0.1,::1"
      },
      "runtime": {
        "type": "node",
        "version": ">=18"
      },
      "npmRegistry": "https://registry.npmmirror.com"
    }
  }
}