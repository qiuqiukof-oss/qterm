{
    "mcpServers": {
        "cloudbase": {
            "command": "npx",
            "args": [
                "-y",
                "@cloudbase/cloudbase-mcp@latest"
            ],
            "runtime": {
                "type": "node",
                "version": ">=20"
            },
            "staticEnv": {
                "INTEGRATION_IDE": "WorkBuddy"
            }
        }
    },
    "preAuth": "cli"
}