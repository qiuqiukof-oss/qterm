# QTerm Environment Variables
# Copy this file to .env and fill in your keys

# Server
PORT=3001
HOST=127.0.0.1

# AI Chat API Keys (BYOK - Bring Your Own Key)
# 至少配置一个 AI 提供商才能使用 AI 聊天功能
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Stability AI API Key (可选)
# 用于 AI 生图工具（generate_image），支持 ultra / core / sd3 模型
# 免费注册: https://platform.stability.ai/account/keys
# 未配置时生图工具返回提示信息
STABILITY_API_KEY=

# Pandoc 路径 (可选)
# 用于文档格式转换工具（convert_document），支持 Markdown↔PDF/DOCX/PPTX/HTML 互转
# 未配置时自动在 PATH 中查找，找不到则降级为内置 Markdown→HTML 转换
# 下载: https://pandoc.org/installing.html
PANDOC_PATH=

# Web Search API Key (可选)
# 配置后 AI 的 web_search 工具会使用 Bing Search API，搜索结果更稳定
# 免费注册: https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
# 未配置时自动降级到 DuckDuckGo 免费搜索（可能不稳定）
BING_SEARCH_API_KEY=

# QTerm API URL (用于 MCP Server 连接)
QCLI_API_URL=http://localhost:4264/api
QCLI_WS_URL=ws://localhost:4264

# MCP Command Execution
QCLI_CMD_TIMEOUT=15000
QCLI_CMD_DRAIN=2000
QCLI_WITH_MCP=0          # 设为 1 时自动启动 MCP 子进程（等价于 --with-mcp 参数）

# Agent 环形缓冲区 (可选)
# Agent PTY 输出日志的最大字符数，超出时自动丢弃旧数据
# 默认 50000（字符），设为 0 使用默认值
AGENT_LOG_MAX_CHARS=50000

# MCP Server 配置 (可选)
QCLI_SESSION_TTL=900000    # Session 过期时间（毫秒，默认 15 分钟）
QCLI_MAX_SESSIONS=10       # 最大并发 Session 数
QCLI_RING_BUFFER=5000      # 终端环形缓冲区大小（行数）
QCLI_WS_TIMEOUT=10000      # WebSocket 连接超时（毫秒）

# MCP 安全配置 (可选)
QCLI_MCP_TOKEN=             # MCP 认证 Token（留空不启用认证）
QCLI_POLICY_PATH=           # MCP 安全策略文件路径（留空使用默认策略）
QCLI_AUDIT_LOG=             # MCP 审计日志文件路径（留空不记录）

# ──────────────────────────────────────────────
# 企业平台配置（工作流 A/B/C）
# ──────────────────────────────────────────────
# 认证模式：local（个人/单令牌模式，默认）/ enterprise（多用户账号强制）
AUTH_MODE=local
# 会话签名密钥（留空则首次启动自动生成并持久化到 data/.session-secret）
SESSION_SECRET=
# 审计日志保留天数（默认 90）
AUDIT_RETENTION_DAYS=90
# 遥测开关：设为 1 开启匿名使用量采集（默认关闭）
TELEMETRY_OPT_IN=0
# 许可模式：community（社区版，默认）/ commercial（商业版，解锁审计/团队/SSO 等）
HESI_LICENSE_MODE=community
# 首管引导（无头部署时创建第一个管理员，二选一或通过 /api/auth/bootstrap）
HESI_BOOTSTRAP_ADMIN_USER=
HESI_BOOTSTRAP_ADMIN_PASS=
